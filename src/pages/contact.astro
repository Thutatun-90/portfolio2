---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as ContactPage } from '../content/contact.md';
---

<MainLayout>

<section class="pt-32 pb-24">
  <div class="max-w-2xl mx-auto px-6 text-center">

    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-10">
      Contact
    </h1>

    <p class="text-muted-foreground text-lg mb-14">
      For commissions, collaborations, or project inquiries.
    </p>

    <div class="prose prose-lg prose-invert max-w-xl mx-auto
                prose-headings:text-foreground
                prose-headings:font-semibold
                prose-headings:tracking-tight
                prose-p:text-muted-foreground
                prose-a:text-foreground
                prose-a:no-underline
                prose-a:border
                prose-a:border-border
                prose-a:px-5
                prose-a:py-3
                prose-a:rounded-lg
                prose-a:inline-block
                prose-a:transition
                hover:prose-a:bg-card
                hover:prose-a:shadow-md">

      <ContactPage />

    </div>

  </div>
</section>

</MainLayout>