---
import MainLayout from '../../layouts/MainLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { getCollections, getImages } from '../../data/imageStore';

const allCollection = {
	id: undefined,
	name: 'All',
};
const collections = [allCollection, ...(await getCollections())];
const { collection } = Astro.params;
const images = await getImages(collection ? { collection } : {});
const base = import.meta.env.BASE_URL;

export const getStaticPaths = async () => {
	return [{ id: undefined }, ...(await getCollections())].map((collection) => {
		return {
			params: { collection: collection.id },
		};
	});
};
---

<MainLayout>
	<section class="py-20 pt-16">
		<div class="container-custom">
			<div class="mb-12 text-center">
				<h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
  Selected Works
</h1>

<p class="text-muted-foreground text-base max-w-xl mx-auto">
  A collection of works across different mediums and studies.
</p>
			</div>

			<div class="flex justify-center mb-10">
				<div class="flex flex-wrap gap-5 justify-center">
  {
    collections.map((collectionBtn) => {
      const isActive = collectionBtn.id === collection;

      return (
        <a
          href={`${base}collections/${collectionBtn.id ? collectionBtn.id : ''}`}
          class={`relative text-sm uppercase tracking-wide transition-all duration-300 ${
            isActive
              ? 'text-black'
              : 'text-gray-500 hover:text-black'
          }`}
        >
          {collectionBtn.name}

          {isActive && (
            <span class="absolute left-0 -bottom-1 w-full h-[1px] bg-black/70"></span>
          )}
        </a>
      );
    })
  }
</div>
			</div>

			<PhotoGrid images={images} />
		</div>
	</section>
</MainLayout>
