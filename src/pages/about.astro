---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
const base = import.meta.env.BASE_URL;
---

<MainLayout>
	<section class="pt-32 pb-20">
		<div class="container-custom">
			<div class="max-w-2xl mx-auto text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-8">
  About
</h1>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
				<div>
					<figure>
  <img
    src={`${base}/images/${profileImage}`}
    alt="Profile image"
    class="w-full h-auto rounded-lg shadow-lg border-8 my-4 border-white md:p-4"
    width="720"
    height="720"
  />

  <figcaption class="text-xs text-muted-foreground/70 mt-3 text-center tracking-wide">
  Sketching in Hoi An, Vietnam — 2026
</figcaption>
</figure>
				</div>

				<div class="prose prose-invert max-w-[680px] mx-auto lg:mx-0 space-y-12">
				<p class="text-lg italic text-muted-foreground/80">
Visual artist working across painting, illustration, and comics, exploring storytelling through image.
</p>
  <AboutPage />
</div>
			</div>
		</div>
	</section>
</MainLayout>
