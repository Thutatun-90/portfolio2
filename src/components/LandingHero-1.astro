---
const base = import.meta.env.BASE_URL;
---

<section class="w-full flex items-center justify-center text-center">
  <div class="max-w-3xl px-6">

    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight mb-4">
      Kaung Kin
    </h1>

    <p class="text-lg text-gray-600 mb-8">
      Illustrator & Visual Artist
    </p>

    <a
      href={`${base}collections`}
      class="inline-block px-6 py-3 border border-black hover:bg-black hover:text-white transition duration-300"
    >
      View Artworks
    </a>

  </div>
</section>