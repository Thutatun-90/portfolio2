---
const base = import.meta.env.BASE_URL;
---

<section class="w-full min-h-[70vh] md:min-h-[90vh] flex items-center justify-center text-center">
  <div class="max-w-3xl px-6 space-y-8">

   <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.2] mb-5 text-foreground mm-name">
  ကောင်းကင်
   </h1>
    <p class="text-lg text-muted-foreground mb-14 tracking-[0.35em] md:tracking-[0.45em]">
      A R T I S T
    </p>

    <a
      href={`${base}collections`}
      class="inline-block px-10 py-3 text-sm uppercase tracking-[0.25em]
      text-foreground
      border border-white/20
      bg-white/[0.06]
      backdrop-blur-xl
      rounded-lg
      shadow-[inset_0_1px_0_rgba(255,255,255,0.15)]
      transition-all duration-300
      hover:bg-white/[0.12]
      hover:border-white/40
      hover:-translate-y-1
      hover:shadow-[0_0_25px_rgba(255,255,255,0.15)]"
    >
      View Artworks
    </a>
  </div>
</section>