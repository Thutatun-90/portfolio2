---
const base = import.meta.env.BASE_URL;
---

<section class="w-full min-h-[40vh] flex items-center justify-center text-center">
  <div class="max-w-3xl px-6">

   <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-1 mm-name">
  ကောင်းကင်
</h1>
    <p class="text-lg text-gray-600 mb-10">
      Illustrator & Visual Artist
    </p>

    <a
      href={`${base}collections`}
      class="inline-block px-10 py-3 text-sm tracking-widest uppercase border border-border bg-card shadow-md transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
    >
      View Artworks
    </a>
  </div>
</section>